# ============================================
# BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# ============================================

# Application
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# PostgreSQL Database
# Local:     postgresql://postgres:postgres@localhost:5432/jobboard
# AWS RDS:   postgresql://user:pass@your-rds-endpoint.rds.amazonaws.com:5432/jobboard
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jobboard
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jobboard
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-this
JWT_EXPIRES_IN=7d

# ElasticSearch
# Local:         http://localhost:9200
# AWS OpenSearch: https://your-domain.us-east-1.es.amazonaws.com
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=changeme

# Apache Kafka
# Local:   localhost:9092
# AWS MSK: b-1.your-cluster.kafka.us-east-1.amazonaws.com:9092
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=jobboard-backend

# AWS (for production deployment)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=jobboard-uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
