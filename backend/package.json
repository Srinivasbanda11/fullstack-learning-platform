{
  "name": "jobboard-backend",
  "version": "1.0.0",
  "description": "Node.js + GraphQL + TypeScript backend for the Job Board platform",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "typeorm migration:run -d src/config/dataSource.ts",
    "migrate:generate": "typeorm migration:generate -d src/config/dataSource.ts",
    "migrate:revert": "typeorm migration:revert -d src/config/dataSource.ts",
    "seed": "ts-node src/database/seeds/index.ts",
    "test": "jest --forceExit",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@apollo/server": "^4.9.0",
    "graphql": "^16.8.0",
    "express": "^4.18.2",
    "typeorm": "^0.3.17",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.1.13",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "@elastic/elasticsearch": "^8.9.0",
    "kafkajs": "^2.2.4",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "express-rate-limit": "^7.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.5.0",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/bcryptjs": "^2.4.3",
    "@types/cors": "^2.8.13",
    "@types/jest": "^29.5.3",
    "typescript": "^5.1.6",
    "ts-node-dev": "^2.0.0",
    "ts-node": "^10.9.1",
    "jest": "^29.6.2",
    "ts-jest": "^29.1.1",
    "eslint": "^8.47.0",
    "@typescript-eslint/parser": "^6.4.0",
    "@typescript-eslint/eslint-plugin": "^6.4.0"
  }
}
